  <!-- WhatsApp flotante (solo en vista de ventas) -->
  <a href="https://wa.me/573107941580" target="_blank" id="whatsapp-float"
    class="fixed bottom-5 right-5 z-40 bg-[#25d366] text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition">
    <i class="fab fa-whatsapp text-3xl"></i>
  </a>


  <!-- ══════ QUIZ ENGINE ══════ -->
  <script define:vars={{ quizData }}>
    const DATA = JSON.parse(quizData);
    const { preguntas, linkPago, precio, nombreProducto, conRegistro,
            webhookUrl, negocioId, usuarioId, pixelEnabled, accentHex } = DATA;

    let currentIdx = 0;
    let score = 0;
    const PASS = 0.75;
    let userData = { type: '', num: '', name: '' };

    // ── DOM refs ──
    const views = {
      sales:        document.getElementById('view-sales-page'),
      quiz:         document.getElementById('view-quiz-app'),
      registration: document.getElementById('view-registration'),
      checkout:     document.getElementById('view-checkout'),
      fail:         document.getElementById('view-fail'),
    };
    const qText       = document.getElementById('q-text');
    const qOptions    = document.getElementById('q-options');
    const qCurrent    = document.getElementById('q-current');
    const qLabel      = document.getElementById('q-label');
    const qScoreLive  = document.getElementById('q-score-live');
    const btnNext     = document.getElementById('btn-next');
    const feedback    = document.getElementById('feedback-area');
    const dots        = document.querySelectorAll('[data-dot]');
    const waFloat     = document.getElementById('whatsapp-float');

    // ── Vista ──
    function switchView(name) {
      Object.values(views).forEach(v => v && v.classList.add('hidden-section'));
      if (views[name]) views[name].classList.remove('hidden-section');
      window.scrollTo(0, 0);
      // Ocultar flotante de WA en quiz/checkout
      if (waFloat) waFloat.style.display = ['quiz', 'checkout', 'registration'].includes(name) ? 'none' : 'flex';
    }

    function scrollToExam() {
      document.getElementById('inicio-examen')?.scrollIntoView({ behavior: 'smooth' });
    }

    // ── Listeners ventas ──
    document.getElementById('btn-header-exam')?.addEventListener('click', scrollToExam);
    document.getElementById('btn-cta-sales')?.addEventListener('click', scrollToExam);
    document.getElementById('btn-start-quiz')?.addEventListener('click', startQuizFlow);
    document.getElementById('btn-exit-quiz')?.addEventListener('click', () => {
      if (confirm('¿Salir del examen? Perderás tu progreso.')) location.reload();
    });
    document.getElementById('btn-retry')?.addEventListener('click', startQuizFlow);

    // ── Registro ──
    if (conRegistro) {
      document.getElementById('reg-form')?.addEventListener('submit', e => {
        e.preventDefault();
        userData = {
          type: document.getElementById('user-doctype').value,
          num:  document.getElementById('user-docnum').value,
          name: document.getElementById('user-fullname').value,
        };
        trackEvent('registration_submitted');
        switchView('checkout');
      });
    }

    // ── Pago ──
    document.getElementById('btn-pay')?.addEventListener('click', () => {
      if (pixelEnabled && typeof fbq !== 'undefined') {
        fbq('track', 'InitiateCheckout', { content_name: nombreProducto, value: precio, currency: 'COP', num_items: 1 });
      }
      if (conRegistro && webhookUrl) registerInBackend();
    });

    async function registerInBackend() {
      try {
        await fetch('https://controla-570877385695.northamerica-northeast1.run.app/api/ingresos/publico', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombre: userData.name.split(' ')[0],
            apellido: userData.name.split(' ').slice(1).join(' '),
            tipoDocumento: userData.type,
            numeroDeDocumento: userData.num,
            valor: precio,
            cuenta: 'Nequi Web',
            tipo: nombreProducto,
            business_id: negocioId,
            usuarioId,
          }),
        });
      } catch (_) {}
    }

    function trackEvent(eventName, extra = {}) {
      if (!webhookUrl) return;
      fetch(webhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain' },
        body: JSON.stringify({ evento: eventName, pagina: nombreProducto, fecha: new Date().toLocaleString('es-CO', { timeZone: 'America/Bogota' }), usuario: userData, ...extra }),
        keepalive: true,
      }).catch(() => {});
    }

    // ── Quiz ──
    function startQuizFlow() {
      currentIdx = 0;
      score = 0;
      switchView('quiz');
      loadQuestion();
    }

    function updateDots() {
      dots.forEach((dot, i) => {
        dot.style.backgroundColor = i < currentIdx ? accentHex : i === currentIdx ? '#ffffff' : 'rgba(255,255,255,0.2)';
        dot.style.opacity = i === currentIdx ? '1' : i < currentIdx ? '0.7' : '0.3';
      });
    }

    function loadQuestion() {
      const q = preguntas[currentIdx];
      const isLast = currentIdx === preguntas.length - 1;

      qText.innerText = q.q;
      qCurrent.innerText = currentIdx + 1;
      qLabel.innerText = isLast ? '¡Última pregunta!' : `Pregunta ${currentIdx + 1} de ${preguntas.length}`;
      qScoreLive.innerText = score > 0 ? `✅ ${score} correctas` : '';
      updateDots();

      qOptions.innerHTML = '';
      feedback.className = 'hidden';
      btnNext.disabled = true;
      btnNext.style.backgroundColor = '';
      btnNext.className = 'w-full bg-gray-100 text-gray-400 font-bold py-4 rounded-xl transition-all text-base cursor-not-allowed';
      btnNext.innerText = 'Selecciona una opción para continuar';

      q.options.forEach((opt, idx) => {
        const btn = document.createElement('button');
        // Botones grandes para móvil
        btn.className = 'w-full text-left p-4 rounded-xl border-2 border-slate-200 bg-white text-slate-700 font-semibold text-base leading-snug active:scale-[0.98] transition-all min-h-[56px]';
        btn.innerHTML = `<span class="inline-block w-7 h-7 rounded-full border-2 border-slate-300 text-xs font-black mr-3 align-middle text-center leading-6 flex-shrink-0">${String.fromCharCode(65 + idx)}</span>${opt}`;
        btn.onclick = () => checkAnswer(btn, idx, q.a);
        qOptions.appendChild(btn);
      });
    }

    function checkAnswer(btn, idx, correct) {
      qOptions.querySelectorAll('button').forEach(b => b.disabled = true);
      feedback.classList.remove('hidden');

      if (idx === correct) {
        score++;
        btn.className = 'w-full text-left p-4 rounded-xl border-2 border-green-500 bg-green-50 text-green-800 font-bold text-base leading-snug min-h-[56px]';
        feedback.innerHTML = '✅ &nbsp;¡Correcto! Muy bien.';
        feedback.className = 'block p-4 rounded-xl bg-green-50 border border-green-200 text-green-800 font-bold text-center text-sm';
        trackEvent('quiz_answer', { pregunta: currentIdx + 1, result: 'ok' });
      } else {
        btn.className = 'w-full text-left p-4 rounded-xl border-2 border-red-400 bg-red-50 text-red-800 font-bold text-base leading-snug min-h-[56px]';
        feedback.innerHTML = '❌ &nbsp;No era esa. La respuesta correcta está resaltada en verde.';
        feedback.className = 'block p-4 rounded-xl bg-orange-50 border border-orange-200 text-orange-800 font-bold text-center text-sm';
        const opts = qOptions.querySelectorAll('button');
        opts[correct].className = 'w-full text-left p-4 rounded-xl border-2 border-green-500 bg-green-50 text-green-800 font-semibold text-base leading-snug min-h-[56px]';
        trackEvent('quiz_answer', { pregunta: currentIdx + 1, result: 'fail' });
      }

      const isLast = currentIdx === preguntas.length - 1;
      btnNext.disabled = false;
      btnNext.style.backgroundColor = accentHex;
      btnNext.className = 'w-full text-white font-black py-4 rounded-xl transition-all text-base cursor-pointer active:scale-95';
      btnNext.innerText = isLast ? '📋 Ver mi resultado' : 'Siguiente pregunta →';
    }

    btnNext?.addEventListener('click', () => {
      currentIdx++;
      if (currentIdx < preguntas.length) {
        loadQuestion();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        finishQuiz();
      }
    });

    function finishQuiz() {
      const passed = (score / preguntas.length) >= PASS;
      if (passed) {
        trackEvent('quiz_passed', { score: `${score}/${preguntas.length}` });
        if (pixelEnabled && typeof fbq !== 'undefined') {
          fbq('track', 'Lead', { content_name: `Examen Aprobado - ${nombreProducto}`, value: precio, currency: 'COP' });
        }
        if (conRegistro && !userData.name) {
          switchView('registration');
        } else {
          switchView('checkout');
        }
      } else {
        trackEvent('quiz_failed', { score: `${score}/${preguntas.length}` });
        const pct = Math.round((score / preguntas.length) * 100);
        const txt = document.getElementById('fail-score-text');
        if (txt) txt.innerText = `${score} / ${preguntas.length} (${pct}%)`;
        switchView('fail');
      }
    }
  </script>

</BaseLayout>
