---
import '../styles/global.css';
const apiBackend = import.meta.env.PUBLIC_API_BACKEND ?? 'https://backendcoalianza.vercel.app';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Verificación de Certificados | CertiTec Colombia</title>
  <link rel="icon" href="/logopagina.png" type="image/png" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

  <style is:global>
    body { font-family: 'Inter', sans-serif !important; background-color: #f9fafb; }

    /* Marca */
    .brand-bg        { background-color: #1a3c5e; }
    .brand-bg-hover  { background-color: #122c47; }
    .brand-text      { color: #1a3c5e; }
    .brand-bg-soft   { background-color: rgba(26,60,94,0.08); }
    .brand-border    { border-color: rgba(26,60,94,0.2); }

    /* Toast */
    .toast-item {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 14px 16px; border-radius: 12px; border: 1px solid;
      background: #fff; box-shadow: 0 8px 24px -4px rgba(0,0,0,0.12);
      max-width: 360px; animation: slideInRight 0.25s ease-out;
      pointer-events: auto;
    }
    @keyframes slideInRight {
      from { opacity:0; transform: translateX(20px); }
      to   { opacity:1; transform: translateX(0); }
    }
    .toast-loading { border-color: #bfdbfe; }
    .toast-success { border-color: #bbf7d0; }
    .toast-error   { border-color: #fecaca; }

    /* Card curso generada dinámicamente */
    .course-card { background:#fff; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden; }
    .course-card-header { padding:16px 24px; border-bottom:1px solid #f3f4f6; display:flex; align-items:flex-start; justify-content:space-between; gap:16px; }
    .course-card-dates  { padding:12px 24px; display:grid; grid-template-columns:1fr 1fr; gap:16px; background:#f9fafb; border-bottom:1px solid #f3f4f6; font-size:12px; }
    .course-card-legal  { width:100%; padding:10px 24px; display:flex; align-items:center; justify-content:space-between; font-size:12px; color:#9ca3af; border:none; background:none; border-bottom:1px solid #f3f4f6; cursor:pointer; transition:color 0.15s; }
    .course-card-legal:hover { color:#4b5563; }
    .course-card-legal-body { padding:12px 24px; font-size:12px; color:#6b7280; background:#f9fafb; border-bottom:1px solid #f3f4f6; line-height:1.6; }
    .course-card-actions { padding:16px 24px; display:flex; flex-wrap:wrap; gap:8px; }

    .btn-download-primary {
      display:flex; align-items:center; gap:8px;
      padding:8px 16px; background:#1a3c5e; color:#fff;
      font-size:12px; font-weight:600; border-radius:8px;
      border:none; cursor:pointer; transition:background 0.15s;
    }
    .btn-download-primary:hover:not(:disabled) { background:#122c47; }
    .btn-download-primary:disabled { opacity:0.5; cursor:not-allowed; }

    .btn-download-outline {
      display:flex; align-items:center; gap:8px;
      padding:8px 16px; border:1px solid #d1d5db; color:#4b5563;
      font-size:12px; font-weight:600; border-radius:8px;
      background:#fff; cursor:pointer; transition:all 0.15s;
    }
    .btn-download-outline:hover:not(:disabled) { border-color:#1a3c5e; color:#1a3c5e; }
    .btn-download-outline:disabled { opacity:0.5; cursor:not-allowed; }

    .rotate-180 { transform: rotate(180deg); }
    .hidden { display: none !important; }
  </style>
</head>
<body class="antialiased text-gray-800 min-h-screen flex flex-col">

  <!-- CABECERA -->
  <header class="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-40">
    <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <!-- Bandera Colombia -->
        <svg viewBox="0 0 3 2" class="w-7 h-5 rounded-sm shadow-sm" xmlns="http://www.w3.org/2000/svg">
          <rect width="3" height="1" fill="#FCD116"/>
          <rect y="1" width="3" height="0.5" fill="#003893"/>
          <rect y="1.5" width="3" height="0.5" fill="#CE1126"/>
        </svg>
        <div>
          <p class="font-bold brand-text text-sm leading-tight tracking-tight">Portal de Verificación de Certificados</p>
          <p class="text-[10px] text-gray-400 tracking-wide">Colombia · Validez Nacional</p>
        </div>
      </div>
      <a href="/" class="flex items-center gap-1.5 text-xs text-gray-500 hover:brand-text transition-colors">
        <i class="fas fa-arrow-left text-xs"></i> Volver
      </a>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12 flex-grow w-full">

    <!-- ── VISTA: FORMULARIO DE BÚSQUEDA ── -->
    <div id="view-search">
      <div class="max-w-md mx-auto">

        <div class="flex flex-col items-center mb-8 text-center">
          <div class="w-14 h-14 rounded-2xl brand-bg-soft flex items-center justify-center mb-4">
            <i class="fas fa-shield-alt text-2xl brand-text"></i>
          </div>
          <h1 class="text-xl font-bold text-gray-900">Verificación de Certificados</h1>
          <p class="text-sm text-gray-500 mt-2 max-w-xs leading-relaxed">
            Ingrese su número de documento para consultar y descargar sus certificados oficiales.
          </p>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
          <div class="px-8 py-7 space-y-5">

            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-widest mb-2">
                Número de Documento
              </label>
              <div class="relative">
                <i class="fas fa-fingerprint absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400" style="font-size:18px"></i>
                <input
                  id="cedula-input"
                  type="text"
                  inputmode="numeric"
                  placeholder="Ej: 1012345678"
                  maxlength="12"
                  class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 transition text-base text-gray-900 placeholder:text-gray-300 bg-gray-50 focus:bg-white"
                  style="focus:border-color:#1a3c5e"
                />
              </div>
              <p class="mt-1.5 text-[11px] text-gray-400">Solo números, sin puntos ni espacios</p>
            </div>

            <!-- Error -->
            <div id="error-msg" class="hidden flex items-start gap-2.5 p-3 bg-red-50 border border-red-100 rounded-xl text-sm text-red-700">
              <i class="fas fa-exclamation-circle flex-shrink-0 mt-0.5"></i>
              <span id="error-text"></span>
            </div>

            <button id="search-btn"
              class="w-full py-3 brand-bg text-white font-semibold rounded-xl transition flex items-center justify-center gap-2 text-sm"
              style="background-color:#1a3c5e">
              <i class="fas fa-search"></i> Consultar certificados
            </button>
          </div>

          <div class="px-8 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-center gap-2 text-[11px] text-gray-400">
            <i class="fas fa-shield-alt text-gray-400 text-xs"></i>
            Consulta segura · Información confidencial
          </div>
        </div>
      </div>
    </div>

    <!-- ── VISTA: RESULTADOS ── -->
    <div id="view-results" class="hidden space-y-5">

      <!-- Titular -->
      <div class="bg-white border border-gray-200 rounded-2xl shadow-sm px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div id="student-avatar"
            class="w-12 h-12 rounded-xl brand-bg flex items-center justify-center text-white text-lg font-bold flex-shrink-0"
            style="background-color:#1a3c5e">?</div>
          <div>
            <h2 id="student-name" class="text-base font-bold text-gray-900 capitalize leading-tight"></h2>
            <p id="student-doc" class="text-sm text-gray-500 mt-0.5"></p>
          </div>
        </div>
        <button id="reset-btn"
          class="flex items-center gap-1.5 text-xs font-semibold brand-text border px-4 py-2 rounded-lg transition"
          style="color:#1a3c5e; border-color:rgba(26,60,94,0.2); background:rgba(26,60,94,0.05)">
          <i class="fas fa-search text-xs"></i> Consultar otro documento
        </button>
      </div>

      <!-- Título sección -->
      <div class="flex items-center gap-2 px-1">
        <i class="fas fa-clock text-gray-400 text-sm"></i>
        <p class="text-sm font-semibold text-gray-600">Certificaciones disponibles</p>
        <span id="courses-count" class="ml-auto text-xs text-gray-400"></span>
      </div>

      <!-- Cards cursos (generadas dinámicamente) -->
      <div id="course-cards"></div>

      <!-- Nota de descarga -->
      <div class="bg-white border border-gray-200 rounded-xl px-6 py-4 text-xs text-gray-500 leading-relaxed">
        <p class="font-semibold text-gray-700 mb-1">¿Dónde encontrar el archivo descargado?</p>
        <p>El archivo se guarda en la carpeta <strong>Descargas</strong> de su dispositivo.
          En Android: <em>Mis Archivos → Descargas</em>. En iPhone: App <em>Archivos → Descargas</em>.</p>
      </div>

    </div>
  </main>

  <!-- PIE -->
  <footer class="border-t border-gray-200 mt-auto">
    <div class="max-w-3xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-[11px] text-gray-400">
      <div class="flex items-center gap-2">
        <svg viewBox="0 0 3 2" class="w-6 h-4 rounded-sm" xmlns="http://www.w3.org/2000/svg">
          <rect width="3" height="1" fill="#FCD116"/>
          <rect y="1" width="3" height="0.5" fill="#003893"/>
          <rect y="1.5" width="3" height="0.5" fill="#CE1126"/>
        </svg>
        <span>Portal de Verificación de Certificados · República de Colombia</span>
      </div>
      <span id="footer-year">Res. 2674/2013 · Dec. 3075/1997 · © 2026</span>
    </div>
  </footer>

  <!-- Contenedor de toasts -->
  <div id="toast-container" class="fixed top-4 right-4 z-50 space-y-2 pointer-events-none" style="max-width:360px"></div>

  <script is:inline define:vars={{ apiBackend }}>
    const API = apiBackend;
    const ENDPOINT_CEDULA = (cedula) => `${API}/clients/${cedula}`;

    let studentData = null;
    let downloading = null;

    // ── Utilidades ────────────────────────────────────────────

    function fmt(ds) {
      return new Date(ds).toLocaleDateString('es-CO', {
        day: 'numeric', month: 'long', year: 'numeric'
      });
    }

    function extractIntensity(name) {
      if (!name) return '10';
      const nums = name.match(/(\d+)/g);
      return nums?.length ? nums[nums.length - 1] : '10';
    }

    function isFoodHandling(name) {
      const n = name.toLowerCase();
      return n.includes('manipulac') || n.includes('alimentos');
    }

    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
        .replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ── Toast ─────────────────────────────────────────────────

    function showToast(type, message, description) {
      const container = document.getElementById('toast-container');
      const id = 'toast-' + Date.now();
      const icons = {
        loading: '<i class="fas fa-spinner fa-spin text-blue-500"></i>',
        success: '<i class="fas fa-check-circle text-emerald-500"></i>',
        error:   '<i class="fas fa-exclamation-circle text-red-500"></i>',
      };
      const el = document.createElement('div');
      el.id = id;
      el.className = `toast-item toast-${type}`;
      el.innerHTML = `
        <span class="flex-shrink-0 mt-0.5">${icons[type]}</span>
        <div>
          <p class="font-semibold text-sm text-gray-900">${escHtml(message)}</p>
          ${description ? `<p class="text-xs text-gray-500 mt-0.5">${escHtml(description)}</p>` : ''}
        </div>`;
      container.appendChild(el);
      if (type !== 'loading') setTimeout(() => el.remove(), 6000);
      return id;
    }

    function removeToast(id) {
      document.getElementById(id)?.remove();
    }

    // ── Vistas ────────────────────────────────────────────────

    function switchView(name) {
      ['view-search', 'view-results'].forEach(id =>
        document.getElementById(id).classList.add('hidden')
      );
      document.getElementById(name).classList.remove('hidden');
      window.scrollTo(0, 0);
    }

    // ── API ───────────────────────────────────────────────────

    async function getClientByCedula(cedula) {
      const res = await fetch(ENDPOINT_CEDULA(cedula));
      if (!res.ok) {
        const err = new Error('Error');
        err.status = res.status;
        throw err;
      }
      return res.json();
    }

    // ── Validar / Buscar ──────────────────────────────────────

    async function handleValidate() {
      const cedula = document.getElementById('cedula-input').value.trim();
      const errorEl = document.getElementById('error-msg');
      const errorText = document.getElementById('error-text');
      const btn = document.getElementById('search-btn');

      errorEl.classList.add('hidden');

      if (!cedula || cedula.length < 5) {
        errorText.textContent = 'Ingrese un número de documento válido (mínimo 5 dígitos).';
        errorEl.classList.remove('hidden');
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Consultando…';

      try {
        const data = await getClientByCedula(cedula);
        if (!data || !data.numeroDeDocumento) throw new Error('Datos inválidos.');
        studentData = data;
        renderResults(data);
        switchView('view-results');
      } catch (err) {
        studentData = null;
        errorText.textContent = err.status === 404
          ? 'El documento no registra certificaciones activas en nuestra base de datos.'
          : 'No fue posible conectarse con el servidor. Intente nuevamente.';
        errorEl.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-search mr-2"></i>Consultar certificados';
      }
    }

    // ── Renderizar resultados ─────────────────────────────────

    function renderResults(data) {
      document.getElementById('student-avatar').textContent =
        (data.nombre || '?').charAt(0).toUpperCase();
      document.getElementById('student-name').textContent =
        `${data.nombre || ''} ${data.apellido || ''}`.trim();
      const docType = data.tipoDeDocumento || data.tipoDocumento || data.tipo_documento || 'C.C.';
      document.getElementById('student-doc').textContent =
        `${docType} ${data.numeroDeDocumento}`;

      const cursos = Array.isArray(data.tipo) ? data.tipo : [];
      document.getElementById('courses-count').textContent = `${cursos.length} registro(s)`;

      const container = document.getElementById('course-cards');
      if (cursos.length === 0) {
        container.innerHTML = `
          <div class="bg-white border border-gray-200 rounded-xl p-10 text-center text-gray-400 text-sm">
            No hay certificaciones activas para este usuario.
          </div>`;
        return;
      }

      container.innerHTML = cursos.map((curso, idx) => buildCourseCard(curso, data, idx)).join('');

      // Toggle referencias legales
      container.querySelectorAll('[data-toggle]').forEach(btn => {
        btn.addEventListener('click', () => {
          const target = document.getElementById(btn.dataset.toggle);
          target.classList.toggle('hidden');
          btn.querySelector('.toggle-icon').classList.toggle('rotate-180');
        });
      });

      // Botones de descarga
      container.querySelectorAll('[data-download]').forEach(btn => {
        btn.addEventListener('click', () =>
          handleDownload(btn.dataset.download, btn.dataset.course)
        );
      });
    }

    function buildCourseCard(courseName, data, idx) {
      const intensity = extractIntensity(courseName);
      const food = isFoodHandling(courseName);
      const legalId = `legal-${idx}`;
      const name = escHtml(courseName);

      return `
        <div class="course-card mb-3">
          <!-- Cabecera -->
          <div class="course-card-header">
            <div style="display:flex;align-items:center;gap:12px">
              <div style="width:36px;height:36px;border-radius:8px;background:rgba(26,60,94,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="fas fa-award" style="color:#1a3c5e;font-size:16px"></i>
              </div>
              <div>
                <p style="font-weight:600;color:#111827;font-size:14px;line-height:1.3">${name}</p>
                <p style="font-size:12px;color:#9ca3af;margin-top:2px">
                  Intensidad: <span style="font-weight:500;color:#4b5563">${intensity} horas</span>
                </p>
              </div>
            </div>
            <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;color:#065f46;background:#ecfdf5;border:1px solid #a7f3d0;padding:2px 8px;border-radius:9999px;flex-shrink:0">
              <i class="fas fa-check-circle" style="font-size:10px"></i> Vigente
            </span>
          </div>

          <!-- Fechas -->
          <div class="course-card-dates">
            <div>
              <p style="color:#9ca3af;margin-bottom:2px">Fecha de expedición</p>
              <p style="font-weight:500;color:#374151">${data.createdAt ? fmt(data.createdAt) : '—'}</p>
            </div>
            <div>
              <p style="color:#9ca3af;margin-bottom:2px">Fecha de vencimiento</p>
              <p style="font-weight:500;color:#374151">${data.fechaVencimiento ? fmt(data.fechaVencimiento) : '—'}</p>
            </div>
          </div>

          ${food ? `
          <button class="course-card-legal" data-toggle="${legalId}">
            <span>Resolución 2674/2013 — Decreto 3075/1997</span>
            <i class="fas fa-chevron-down toggle-icon" style="font-size:12px;transition:transform 0.2s"></i>
          </button>
          <div id="${legalId}" class="hidden course-card-legal-body">
            Certificado con validez nacional en Colombia. Expedido conforme a la normativa de inocuidad
            alimentaria vigente ante entes de control en todo el territorio de la República.
          </div>
          ` : ''}

          <!-- Acciones -->
          <div class="course-card-actions">
            <button class="btn-download-primary" data-download="certificado" data-course="${name}">
              <i class="fas fa-cloud-arrow-down" style="font-size:13px"></i> Descargar certificado
            </button>
            ${food ? `
            <button class="btn-download-outline" data-download="carnet" data-course="${name}">
              <i class="fas fa-id-card" style="font-size:13px"></i> Descargar carnet
            </button>
            ` : ''}
          </div>
        </div>`;
    }

    // ── Descarga ──────────────────────────────────────────────

    async function handleDownload(docType, courseName) {
      if (downloading) return;
      downloading = docType;

      // Deshabilitar todos los botones de descarga
      document.querySelectorAll('[data-download]').forEach(b => b.disabled = true);

      // Actualizar icono del botón pulsado
      const btn = document.querySelector(`[data-download="${docType}"][data-course="${courseName}"]`);
      const originalHTML = btn?.innerHTML;
      if (btn) btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="font-size:13px"></i> Generando…';

      const toastId = showToast('loading', 'Generando documento…', 'Espere unos segundos. No cierre esta página.');
      const intensity = extractIntensity(courseName);

      try {
        const { nombre, apellido, numeroDeDocumento } = studentData;
        const tipoDocumento =
          studentData.tipoDeDocumento || studentData.tipoDocumento ||
          studentData.tipo_documento || 'C.C';

        let endpoint, opts;

        if (docType === 'certificado') {
          endpoint = courseName.toLowerCase().includes('excel')
            ? `${API}/api/generar-certificado-pdf`
            : `${API}/api/generar-certificado`;
          opts = {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              nombre: `${nombre} ${apellido}`,
              numeroDocumento: numeroDeDocumento,
              tipoDocumento,
              curso: courseName,
              intensidadHoraria: intensity,
            }),
          };
        } else {
          endpoint = `${API}/api/generar-carnet`;
          const fd = new FormData();
          fd.append('nombre', `${nombre} ${apellido}`);
          fd.append('numeroDocumento', numeroDeDocumento);
          fd.append('tipoDocumento', tipoDocumento);
          fd.append('intensidadHoraria', intensity);
          opts = { method: 'POST', body: fd };
        }

        const res = await fetch(endpoint, opts);
        if (!res.ok) throw new Error('Error del servidor');

        const blob = await res.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${docType}_${nombre}_${apellido}.pdf`.replace(/\s+/g, '_');
        document.body.appendChild(a);
        a.click();
        a.remove();
        window.URL.revokeObjectURL(url);

        removeToast(toastId);
        showToast('success', 'Descarga lista', 'Búsquelo en la carpeta Descargas de su dispositivo.');
      } catch {
        removeToast(toastId);
        showToast('error', 'Error al generar', 'No se pudo generar el documento. Intente nuevamente.');
      } finally {
        downloading = null;
        document.querySelectorAll('[data-download]').forEach(b => b.disabled = false);
        if (btn && originalHTML) btn.innerHTML = originalHTML;
      }
    }

    // ── Reset ─────────────────────────────────────────────────

    function reset() {
      studentData = null;
      document.getElementById('cedula-input').value = '';
      document.getElementById('error-msg').classList.add('hidden');
      switchView('view-search');
    }

    // ── Listeners ─────────────────────────────────────────────

    document.getElementById('cedula-input').addEventListener('input', e => {
      e.target.value = e.target.value.replace(/\D/g, '');
    });

    document.getElementById('cedula-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') handleValidate();
    });

    document.getElementById('search-btn').addEventListener('click', handleValidate);
    document.getElementById('reset-btn').addEventListener('click', reset);

    // Focus automático al cargar
    document.getElementById('cedula-input').focus();
  </script>
</body>
</html>
