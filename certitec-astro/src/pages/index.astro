---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseCard from '../components/CourseCard.astro';
import { cursos } from '../data/cursos';
import '../styles/global.css';
---

<BaseLayout title="CertiTec Colombia — Certificaciones Profesionales">
  <!-- HEADER -->
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200">
    <div class="container mx-auto max-w-5xl px-4 py-4 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <img src="/logopagina.png" alt="CertiTec" class="h-10 w-auto" onerror="this.style.display='none'" />
        <div class="leading-none">
          <p class="text-xl font-bold text-slate-900 tracking-tight">
            CertiTec <span class="text-blue-600">Colombia</span>
          </p>
          <span class="text-[10px] text-slate-500 uppercase tracking-widest">Formación Virtual</span>
        </div>
      </div>
      <nav class="hidden md:flex gap-6 text-sm font-medium text-slate-600">
        <a href="#cursos" class="hover:text-slate-900 transition">Cursos</a>
        <a href="#beneficios" class="hover:text-slate-900 transition">Nosotros</a>
        <a href="https://wa.me/573107941580" class="hover:text-slate-900 transition">Contacto</a>
      </nav>
      <a href="https://wa.me/573107941580" class="text-xs font-bold border border-slate-300 text-slate-700 px-4 py-2 rounded-full hover:bg-slate-100 transition">
        SOPORTE
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative pt-20 pb-32 px-4 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-full z-0 opacity-20 pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-sky-300 rounded-full mix-blend-multiply filter blur-3xl animate-pulse"></div>
      <div class="absolute bottom-20 right-10 w-72 h-72 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl animate-pulse" style="animation-delay: 2s"></div>
    </div>
    <div class="container mx-auto max-w-3xl text-center relative z-10">
      <div class="inline-flex items-center bg-white/70 border border-slate-200 rounded-full px-3 py-1 mb-6">
        <span class="flex h-2 w-2 rounded-full bg-green-500 mr-2 animate-ping"></span>
        <span class="text-xs text-slate-600 font-medium">Certificaciones Legales</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 leading-tight tracking-tight">
        Impulsa tu Hoja de Vida<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-blue-700">
          Sin Salir de Casa
        </span>
      </h1>
      <p class="text-lg text-slate-600 mb-10 max-w-xl mx-auto">
        Plataforma líder en cursos cortos y diplomados con validez nacional. Estudia, aprueba y descarga tu certificado el mismo día.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#cursos" class="btn-gradient text-white font-bold py-4 px-8 rounded-xl shadow-lg shadow-blue-500/20">
          Ver Catálogo de Cursos
        </a>
        <a href="https://wa.me/573107941580" target="_blank" class="bg-white hover:bg-slate-50 text-slate-900 font-bold py-4 px-8 rounded-xl border border-slate-200 transition">
          Hablar con Asesor
        </a>
      </div>
    </div>
  </section>

  <!-- CATÁLOGO -->
  <section id="cursos" class="py-16 bg-slate-50 border-y border-slate-200">
    <div class="container mx-auto max-w-5xl px-4">
      <div class="mb-10">
        <h2 class="text-3xl font-bold text-slate-900 mb-2">Nuestros Cursos</h2>
        <p class="text-slate-600 text-sm">Selecciona el programa que necesitas para tu trabajo.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {cursos.map(curso => <CourseCard curso={curso} />)}
      </div>
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section id="beneficios" class="py-16 px-4">
    <div class="container mx-auto max-w-5xl">
      <div class="bg-gradient-to-br from-white to-slate-50 rounded-3xl p-8 md:p-12 border border-slate-200 shadow-2xl">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div>
            <h2 class="text-3xl font-bold text-slate-900 mb-4">¿Por qué elegir CertiTec?</h2>
            <ul class="space-y-4">
              <li class="flex items-start">
                <i class="fas fa-check-circle text-green-500 mt-1 mr-3"></i>
                <span class="text-slate-600 text-sm"><strong>Legalidad Garantizada:</strong> Cumplimos con todas las normativas vigentes en Colombia.</span>
              </li>
              <li class="flex items-start">
                <i class="fas fa-bolt text-yellow-500 mt-1 mr-3"></i>
                <span class="text-slate-600 text-sm"><strong>Velocidad:</strong> Sin esperas. Estudias, apruebas y recibes tu certificado el mismo día.</span>
              </li>
              <li class="flex items-start">
                <i class="fas fa-mobile-alt text-blue-500 mt-1 mr-3"></i>
                <span class="text-slate-600 text-sm"><strong>100% Móvil:</strong> Plataforma diseñada para que uses tu celular sin problemas.</span>
              </li>
            </ul>
          </div>
          <div class="text-center">
            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-md inline-block">
              <p class="text-4xl font-black text-slate-900 mb-1">+5.000</p>
              <p class="text-sm text-slate-500">Estudiantes Certificados</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-white py-10 border-t border-slate-200 text-center">
    <div class="container mx-auto max-w-5xl px-4">
      <img src="/logopagina.png" alt="Logo" class="h-8 mx-auto mb-6 opacity-80" onerror="this.style.display='none'" />
      <p class="text-slate-500 text-xs mb-4">
        &copy; 2024 CertiTec Colombia - Corporación Educativa Conalianza.<br />
        Todos los derechos reservados.
      </p>
      <div class="flex justify-center gap-4 text-slate-600 text-sm">
        <a href="#" class="hover:text-slate-900">Términos</a>
        <a href="#" class="hover:text-slate-900">Privacidad</a>
        <a href="https://wa.me/573107941580" class="hover:text-slate-900">Soporte</a>
      </div>
    </div>
  </footer>

  <!-- WhatsApp flotante -->
  <a href="https://wa.me/573107941580" target="_blank"
    class="fixed bottom-5 right-5 z-50 bg-[#25d366] text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition">
    <i class="fab fa-whatsapp text-3xl"></i>
  </a>
</BaseLayout>
