---
import type { Curso } from '../data/cursos';

export interface Props {
  curso: Curso;
}
const { curso } = Astro.props;

const precio = curso.precio.toLocaleString('es-CO');
---

<div class="premium-card rounded-2xl p-6 flex flex-col h-full relative overflow-hidden group">
  {curso.badgeTexto && (
    <div class={`absolute top-0 right-0 ${curso.badgeClase} text-white text-[10px] font-bold px-2 py-1 rounded-bl-lg z-10`}>
      {curso.badgeTexto}
    </div>
  )}

  <div
    class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition"
    style={`background-color: ${curso.accentHex}22; color: ${curso.accentHex};`}
  >
    <i class={`fas ${curso.icono}`}></i>
  </div>

  <h3 class="text-xl font-bold text-slate-900 mb-2">
    {curso.titulo} {curso.tituloResaltado}
  </h3>
  <p class="text-sm text-slate-600 mb-4 flex-grow">{curso.descripcionHero}</p>

  <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-200">
    <span class="text-2xl font-bold text-slate-900">${precio}</span>
    <a
      href={`/cursos/${curso.slug}`}
      class="text-blue-600 text-sm font-bold hover:text-blue-500 flex items-center"
    >
      Iniciar <i class="fas fa-arrow-right ml-2"></i>
    </a>
  </div>
</div>
